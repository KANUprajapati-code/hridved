# --- RAZORPAY CONFIG ---
# Get these from Razorpay Dashboard > Settings > API Keys
RAZORPAY_KEY_ID=rzp_test_your_key_id
RAZORPAY_KEY_SECRET=your_razorpay_key_secret

# Get this from Razorpay Dashboard > Settings > Webhooks
# You MUST set this secret when creating the webhook in Razorpay dashboard
# Use the same secret here.
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret_here

# --- DATABASE CONFIG ---
MONGO_URI=mongodb+srv://username:password@cluster.mongodb.net/hridved

# --- SERVER CONFIG ---
PORT=5000
NODE_ENV=production

# --- SHIPPING (FSHIP) ---
# Use your Hridved Fship API Key here
FSHIP_TOKEN=your_fship_token_here
FSHIP_BASE_URL=https://api.fship.in/

# --- JWT ---
JWT_SECRET=your_super_secret_jwt_key
